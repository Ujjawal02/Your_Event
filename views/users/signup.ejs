<%layout("/layouts/boilerplate")%>

<body>
    <div class="row">
        <div class="col-6 offset-3">
        <h3>SignUp</h3>
        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label"><i class="fas fa-crown"></i>Username</label>
                <input type="text" name="username" placeholder="enter title" class="form-control" required>
                <div class="valid-feedback">Title Looks Good!</div>
                <div class="invalid-feedback">Please enter valid username</div>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label"><i class="fas fa-crown"></i>Email</label>
                <input type="text" name="email" placeholder="enter title" class="form-control" required>
                <div class="valid-feedback">Title Looks Good!</div>
                <div class="invalid-feedback">Please enter valid email</div>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label"><i class="fas fa-crown"></i>Password</label>
                <input type="password" name="password" placeholder="enter title" class="form-control" required>
                <div class="valid-feedback">Title Looks Good!</div>
                <div class="invalid-feedback">Please enter valid password</div>
            </div>
            <button class="btn btn-primary">SignUp</button>
        </form>
        </div>
    </div>
</body>